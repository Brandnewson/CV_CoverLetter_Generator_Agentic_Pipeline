# Environment Configuration
# Copy this file to .env and fill in your values

# PostgreSQL connection string
DATABASE_URL=postgresql://localhost/job_pipeline

# OpenAI API key (for job scoring in Stage 1)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API key (for CV generation in Stage 2)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model to use for CV generation
# Options: claude-haiku-4-5-20251001, claude-sonnet-4-6, claude-opus-4-6, etc.
# Default: claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-haiku-4-5-20251001
